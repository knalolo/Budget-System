# ============================================================
# Environment variables for the Procurement System
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ============================================================

# ------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------

# REQUIRED: Generate a strong secret key before deploying.
# Example: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-strong-secret-key

# Comma-separated list of hostnames allowed to serve the app (production only).
# Example: procurement.example.com,www.procurement.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------
# Database (PostgreSQL — production / docker)
# ------------------------------------------------------------------

DB_NAME=procurement_db
DB_USER=procurement_user
DB_PASSWORD=change-me-db-password
DB_HOST=db
DB_PORT=5432

# ------------------------------------------------------------------
# Azure Active Directory / MSAL (Microsoft SSO)
# ------------------------------------------------------------------

# The Azure AD tenant ID (found in Azure Portal > Azure Active Directory > Overview)
AZURE_AD_TENANT_ID=your-tenant-id-here

# The application (client) ID registered in Azure AD
AZURE_AD_CLIENT_ID=your-client-id-here

# The client secret value created under Certificates & Secrets
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# The redirect URI registered in Azure AD (must match exactly)
AZURE_AD_REDIRECT_URI=http://localhost:8000/auth/callback/

# ------------------------------------------------------------------
# Email (Microsoft 365 / SMTP)
# ------------------------------------------------------------------

EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ------------------------------------------------------------------
# Security (production only)
# ------------------------------------------------------------------

# Set to False only if you are behind a TLS-terminating proxy that
# does not send HTTPS to Django (not recommended for most setups).
SECURE_SSL_REDIRECT=True
